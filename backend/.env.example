# APPLICATION
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# DATABASE
DB_HOST=snowshelf_mariadb
DB_PORT=3306
DB_USERNAME=snowshelf_user
DB_PASSWORD=snowshelf_password
DB_DATABASE=snowshelf_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# REDIS
REDIS_HOST=snowshelf_redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# TAKO API
TAKO_API_URL=http://snowshelf_tako_api:3001
TAKO_API_TIMEOUT=30000

# CORS
CORS_ORIGIN=http://localhost:5173

# LOGGING
LOG_LEVEL=debug

# FILE UPLOAD
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# EMAIL (MailHog)
MAIL_HOST=snowshelf_mailhog
MAIL_PORT=1025
MAIL_FROM=noreply@snowshelf.fr

# PAGINATION
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

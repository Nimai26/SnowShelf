FROM node:25-alpine

WORKDIR /app

# Installation des dépendances système nécessaires
RUN apk add --no-cache bash curl

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start in development mode with hot reload
CMD ["npm", "run", "start:dev"]

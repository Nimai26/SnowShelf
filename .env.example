# ════════════════════════════════════════════════════════════
# SnowShelf v2 - Variables d'Environnement
# ════════════════════════════════════════════════════════════
#
# Instructions:
# 1. Copier ce fichier: cp .env.example .env
# 2. Remplir les valeurs sensibles (mots de passe, API keys)
# 3. Ne JAMAIS commiter le fichier .env dans git
#
# ════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=SnowShelf
APP_VERSION=2.0.0
PORT=3000

# URLs
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# ──────────────────────────────────────────────────
# DATABASE - MariaDB
# ──────────────────────────────────────────────────
DB_HOST=snowshelf_mariadb
DB_PORT=3306
DB_NAME=snowshelf_db
DB_USER=snowshelf
DB_PASSWORD=CHANGE_ME_db_password
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# ──────────────────────────────────────────────────
# REDIS - Cache & Sessions
# ──────────────────────────────────────────────────
REDIS_HOST=snowshelf_redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ──────────────────────────────────────────────────
# JWT - Authentification
# ──────────────────────────────────────────────────
# IMPORTANT: Générer des secrets forts en production!
# Exemple: openssl rand -base64 64
# IMPORTANT: Générer des secrets forts!
# Exemple: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_jwt_secret
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ──────────────────────────────────────────────────
# TAKO_API - API de recherche unifiée
# ──────────────────────────────────────────────────
TAKO_API_URL=http://snowshelf_tako_api:3000
TAKO_API_TIMEOUT=30000

# ──────────────────────────────────────────────────
# PUSH NOTIFICATIONS (VAPID)
# ──────────────────────────────────────────────────
# Générer avec: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME_vapid_public
VAPID_PRIVATE_KEY=CHANGE_ME_vapid_private
VAPID_SUBJECT=mailto:admin@snowshelf.fr

# ──────────────────────────────────────────────────
# ADMIN PAR DEFAUT
# ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@snowshelf.fr
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password

# PostgreSQL (Cache Tako_Api)
TAKO_DB_HOST=snowshelf_tako_postgres
TAKO_DB_PORT=5432
TAKO_DB_NAME=tako_cache
TAKO_DB_USER=tako
TAKO_DB_PASSWORD=tako_password
TAKO_DB_ENABLED=true

# FlareSolverr (Bypass Cloudflare)
FSR_URL=http://snowshelf_flaresolverr:8191/v1

# ──────────────────────────────────────────────────
# TAKO_API - API Keys (gérées exclusivement par Tako_Api)
# Ces clés sont injectées dans le conteneur Tako_Api.
# Tako_Api ne nécessite AUCUNE authentification pour y accéder depuis SnowShelf.
# Certains providers ne nécessitent pas de clé (scraping / API publique).
# ──────────────────────────────────────────────────
# Construction Toys
REBRICKABLE_API_KEY=
BRICKSET_API_KEY=

# Media
TMDB_API_KEY=
TVDB_API_KEY=

# Videogames
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
RAWG_API_KEY=

# Comics
COMICVINE_API_KEY=

# Music
DISCOG_API_KEY=

# Books
GOOGLE_BOOKS_API_KEY=

# Board Games
BGG_API_TOKEN=

# TCG (Trading Card Games)
TCG_POKEMON_TOKEN=

# ──────────────────────────────────────────────────
# EMAIL
# ──────────────────────────────────────────────────
# Développement (MailHog)
SMTP_HOST=snowshelf_mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@snowshelf.fr
SMTP_SECURE=false

# Production (exemple SendGrid)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxx
# SMTP_FROM=noreply@snowshelf.fr
# SMTP_SECURE=true

# ──────────────────────────────────────────────────
# STORAGE - Minio (S3-compatible)
# ──────────────────────────────────────────────────
# Décommenter si vous utilisez Minio au lieu du stockage local
# MINIO_ENDPOINT=snowshelf_minio
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minio_access_key
# MINIO_SECRET_KEY=minio_secret_key
# MINIO_BUCKET=snowshelf-storage
# MINIO_USE_SSL=false

# ──────────────────────────────────────────────────
# MONITORING (optionnel)
# ──────────────────────────────────────────────────
# SENTRY_DSN=
# GRAFANA_URL=http://localhost:3001
# PROMETHEUS_URL=http://localhost:9090

# ──────────────────────────────────────────────────
# FRONTEND - Vite
# ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=SnowShelf
VITE_APP_VERSION=2.0.0
VITE_TAKO_API_ENABLED=true

# ──────────────────────────────────────────────────
# TIMEZONE
# ──────────────────────────────────────────────────
TZ=Europe/Paris

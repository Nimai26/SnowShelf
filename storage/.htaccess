# =============================================================================
# SÉCURITÉ STORAGE - Empêcher l'exécution de code et protéger les fichiers
# =============================================================================

# Désactiver complètement l'exécution PHP dans ce dossier
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Désactiver les handlers PHP pour les extensions courantes
<FilesMatch "\.(php|php3|php4|php5|php7|phtml|phar|phps|cgi|pl|py|sh|bash|exe|dll|bat|cmd)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Désactiver le moteur PHP (si mod_php est utilisé)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# Supprimer les handlers d'exécution
<IfModule mod_mime.c>
    RemoveHandler .php .php3 .php4 .php5 .php7 .phtml .phar
    RemoveType .php .php3 .php4 .php5 .php7 .phtml .phar
</IfModule>

# Forcer le téléchargement au lieu de l'exécution pour tous les fichiers
<IfModule mod_headers.c>
    <FilesMatch "\.(php|php3|php4|php5|php7|phtml|phar)$">
        Header set Content-Type application/octet-stream
        Header set Content-Disposition attachment
    </FilesMatch>
</IfModule>

# Désactiver le listing des répertoires
Options -Indexes -ExecCGI

# Empêcher l'accès direct aux fichiers (optionnel - décommenter si nécessaire)
# Les fichiers doivent être servis via un script PHP qui vérifie les permissions
# <IfModule mod_authz_core.c>
#     Require all denied
# </IfModule>

# Autoriser uniquement certains types de fichiers
<FilesMatch "\.(?i)(jpe?g|png|gif|webp|svg|ico|mp3|wav|ogg|flac|mp4|webm|avi|mkv|pdf|doc|docx|txt|zip)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>

# Empêcher l'accès aux fichiers cachés et sensibles
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Protection contre les attaques de type null byte
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{QUERY_STRING} (\x00|\x04|\x08|\x0B|\x0C|\x0E-\x1F|\x7F) [NC,OR]
    RewriteCond %{REQUEST_URI} (\x00|\x04|\x08|\x0B|\x0C|\x0E-\x1F|\x7F) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ═══════════════════════════════════════════════════════════
# SnowShelf v2 - Production Environment Variables
# ═══════════════════════════════════════════════════════════
# À copier en .env pour la production
# ⚠️ CHANGER TOUS LES MOTS DE PASSE ET SECRETS !
# ═══════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────
# 📱 Application
# ──────────────────────────────────────────────────────────
APP_NAME=SnowShelf
APP_URL=https://snowshelf.fr
CORS_ORIGIN=https://snowshelf.fr

# ──────────────────────────────────────────────────────────
# 🗄️  Base de données MariaDB
# ──────────────────────────────────────────────────────────
DB_NAME=snowshelf
DB_USER=snowshelf_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# ──────────────────────────────────────────────────────────
# 🔴 Redis Cache
# ──────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ──────────────────────────────────────────────────────────
# 🐙 Tako API PostgreSQL
# ──────────────────────────────────────────────────────────
TAKO_DB_NAME=tako_cache
TAKO_DB_USER=tako_user
TAKO_DB_PASSWORD=CHANGE_ME_TAKO_PASSWORD
TAKO_CACHE_TTL=3600

# ──────────────────────────────────────────────────────────
# 🔐 JWT Secrets
# ──────────────────────────────────────────────────────────
# Générer avec: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# ──────────────────────────────────────────────────────────
# 🌐 Ports (si pas de NGINX Proxy Manager)
# ──────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ──────────────────────────────────────────────────────────
# 📧 Email (optionnel pour prod)
# ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@snowshelf.fr

# ──────────────────────────────────────────────────────────
# 📁 Stockage des médias
# ──────────────────────────────────────────────────────────
# Chemin absolu ou relatif sur la machine hôte
# Contient: users/, default_categories/, avatars/, temp/
STORAGE_PATH=./storage
